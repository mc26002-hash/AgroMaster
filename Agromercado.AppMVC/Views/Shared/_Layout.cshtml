@inject Agromercado.AppMVC.Models.AgroMercadoSprintDbContext _context

@{
    var rolId = Context.Session.GetInt32("RolId");
}

@{
    var productosBajoStock = _context.Productos
        .Where(p => p.Stock <= p.StockMinimo && p.Activo == true)
        .ToList();

    var totalAlertas = productosBajoStock.Count;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AgroMercado</title>

    <!-- Bootstrap PRIMERO -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <!-- TU CSS AL FINAL 🔥 -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            body {
                background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1500382017468-9049fed747ef');
                background-size: cover;
                background-position: center;
                background-attachment: fixed;
            }

            /* SIDEBAR */
            .sidebar {
                width: 240px;
                height: 100vh;
                position: fixed;
                background: linear-gradient(180deg, #2e7d32, #1b5e20);
                color: white;
                padding-top: 20px;
            }

                .sidebar h4 {
                    text-align: center;
                    font-weight: bold;
                    margin-bottom: 30px;
                }

                .sidebar a {
                    display: block;
                    color: white;
                    padding: 12px 20px;
                    text-decoration: none;
                    transition: 0.3s;
                }

                    .sidebar a:hover {
                        background-color: rgba(255,255,255,0.15);
                        padding-left: 25px;
                    }

                .sidebar i {
                    margin-right: 10px;
                }

            /* CONTENIDO */
            .content {
                margin-left: 240px;
                padding: 20px;
            }

            main {
                background: white;
                padding: 25px;
                border-radius: 12px;
                box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            }

            h2 {
                color: #2e7d32;
                font-weight: bold;
            }

            /* FOOTER */
            footer {
                margin-top: 40px;
                text-align: center;
                color: gray;
            }
    </style>
</head>

<body>

    <!-- 🌱 SIDEBAR -->
    <div class="sidebar">
        <h4>🌾 AgroMercado</h4>

        <a asp-controller="Home" asp-action="Index">
            <i class="bi bi-house"></i> Inicio
        </a>

        @if (rolId == 1)
        {
            <a asp-controller="Empleado" asp-action="Index">
                <i class="bi bi-people"></i> Empleados
            </a>

            <a asp-controller="Role" asp-action="Index">
                <i class="bi bi-person-badge"></i> Roles
            </a>

            <a asp-controller="DatosNegocio" asp-action="Index">
                <i class="bi bi-gear"></i> Configuración
            </a>
        }

        @if (rolId == 1 || rolId == 6 || rolId == 8)
        {
            <a asp-controller="Categorias" asp-action="Index">
                <i class="bi bi-tags"></i> Categorías
            </a>

            <a asp-controller="UnidadesMedida" asp-action="Index">
                <i class="bi bi-rulers"></i> Unidades
            </a>
        }

        @if (rolId == 1)
        {
            <a asp-controller="Producto" asp-action="Index">
                <i class="bi bi-box-seam"></i> Productos
            </a>

            <a asp-controller="MovimientosInventario" asp-action="Index">
                <i class="bi bi-arrow-left-right"></i> Movimientos
            </a>
        }
        @if (rolId == 1)
        {
            @* 🔔 ALERTAS *@
        <div class="px-3 mb-3">
            <div class="dropdown">

                <a class="btn btn-success w-100 dropdown-toggle fw-bold"
                       href="#" role="button" data-bs-toggle="dropdown">

                    <i class="bi bi-bell-fill"></i> Alertas

                    @if (totalAlertas > 0)
                    {
                        <span class="badge bg-danger ms-2">@totalAlertas</span>
                    }
                </a>

                <ul class="dropdown-menu w-100">

                    @if (totalAlertas == 0)
                    {
                        <li class="dropdown-item text-muted">
                            <i class="bi bi-check-circle me-2"></i>
                            Sin alertas
                        </li>
                    }
                    else
                    {
                        @foreach (var item in productosBajoStock.Take(5))
                        {
                            <li>
                                    <a class="dropdown-item text-dark custom-item"
                                           asp-controller="Producto"
                                           asp-action="Details"
                                           asp-route-id="@item.Id">

                                        ⚠️ @item.Nombre
                                        <br />
                                        <small class="text-secondary">
                                            Stock: @item.Stock | Mín: @item.StockMinimo
                                        </small>
                                    </a>
                            </li>
                        }

                        <li><hr class="dropdown-divider" /></li>

                        <li>
                            <a class="dropdown-item text-center text-primary fw-bold"
                                   asp-controller="Producto"
                                   asp-action="Alertas">

                                <i class="bi bi-eye"></i> Ver todos
                            </a>
                        </li>
                    }

                </ul>

            </div>
        </div>
        }
        <hr style="border-color: rgba(255,255,255,0.3)" />

        @if (Context.Session.GetString("Usuario") != null)
        {
            <a asp-controller="Account" asp-action="Logout">
                <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
            </a>
        }
    </div>

    <!-- CONTENIDO -->
    <div class="content">
        <main>
            @RenderBody()
        </main>

        <footer>
            <p>&copy; 2026 - AgroMercado 🌱</p>
        </footer>
    </div>

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>