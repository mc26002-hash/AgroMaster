@model Agromercado.AppMVC.Models.UnidadMedidum

<div class="form-create-container">
    <div class="form-create-card">

        <h4 class="titulo-agro mb-4">🌾 Editar Unidad de Medida</h4>

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div class="row">

                <div class="col-md-6 mb-3">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Tipo" class="form-label"></label>
                    <select asp-for="Tipo" class="form-control">
                        <option value="Peso">Peso</option>
                        <option value="Cantidad">Cantidad</option>
                        <option value="Volumen">Volumen</option>
                    </select>
                    <span asp-validation-for="Tipo" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
        <label asp-for="Abreviatura" class="form-label"></label>
        <input asp-for="Abreviatura" class="form-control" />
        <span asp-validation-for="Abreviatura" class="text-danger"></span>
    </div>

    

            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <button type="submit" class="btn btn-warning px-4">
                    <i class="bi bi-pencil-square me-2"></i>Guardar
                </button>

                <a asp-action="Index" class="btn btn-secondary px-4">
                    <i class="bi bi-x-circle me-2"></i>Cancelar
                </a>
            </div>

        </form>

    </div>
</div>