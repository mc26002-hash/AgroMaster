@model Agromercado.AppMVC.Models.UnidadMedidum

<div class="form-create-container">
    <div class="form-create-card">

        <h4 class="titulo-agro mb-4">🌾 Eliminar Unidad de Medida</h4>
<div class="alert alert-danger">
    ¿Seguro que deseas eliminar esta unidad?
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="row">

        <div class="col-md-12">
            <div class="card mt-3">
                <div class="card-body">
    <p><strong>Nombre:</strong> @Model.Nombre</p>
                </div>
            </div>
        </div>

    </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-trash me-2"></i> Eliminar
                </button>

                <a asp-action="Index" class="btn btn-secondary px-4">
                    <i class="bi bi-x-circle me-2"></i> Cancelar
                </a>
            </div>

        </form>

    </div>
</div>