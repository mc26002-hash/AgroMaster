@model IEnumerable<Agromercado.AppMVC.Models.MovimientosInventario>

@{
    ViewData["Title"] = "Movimientos de Inventario";
}

<h2>Movimientos de Inventario</h2>

<p>
    <a asp-action="CrearEntradaInicial" class="btn btn-secondary">
        Stock Inicial
    </a>

    <a asp-action="CrearEntrada" class="btn btn-primary">
        Registrar Entrada
    </a>

    <a asp-action="CrearSalida" class="btn btn-warning">
        Registrar Salida
    </a>
</p>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title mb-3">Buscar Movimientos</h5>

            <form asp-controller="MovimientosInventario" asp-action="Index" method="get">
                <div class="row g-3 align-items-end">

                    <!-- 🔽 Producto -->
                    <div class="col-md-4">
                        <label class="form-label fw-bold text-muted small">Producto</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white">
                                <i class="bi bi-box text-primary"></i>
                            </span>
                            <select name="productoId" class="form-select">
                                <option value="0">Todos</option>
                                @foreach (var prod in ViewBag.Productos)
                                {
                                    <option value="@prod.Id"
                                            selected="@(Context.Request.Query["productoId"] == prod.Id.ToString())">
                                        @prod.Nombre
                                    </option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- 🔽 Tipo Movimiento -->
                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted small">Tipo</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white">
                                <i class="bi bi-arrow-left-right text-primary"></i>
                            </span>
                            <select name="tipoMovimiento" class="form-select">
                                <option value="">Todos</option>
                                <option value="Entrada"
                                        selected="@(Context.Request.Query["tipoMovimiento"] == "Entrada")">
                                    Entrada
                                </option>
                                <option value="Salida"
                                        selected="@(Context.Request.Query["tipoMovimiento"] == "Salida")">
                                    Salida
                                </option>
                                <option value="Entrada Inicial"
                                        selected="@(Context.Request.Query["tipoMovimiento"] == "Entrada Inicial")">
                                    Entrada Inicial
                                </option>
                            </select>
                        </div>
                    </div>

                    <!-- 🔢 Cantidad de registros -->
                    <div class="col-md-2">
                        <label class="form-label fw-bold text-muted small">Mostrar</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white">
                                <i class="bi bi-eye text-primary"></i>
                            </span>

                            <select name="topRegistro" class="form-select">

                                <option value="5"
                                        selected="@(string.IsNullOrEmpty(Context.Request.Query["topRegistro"]) || Context.Request.Query["topRegistro"] == "5")">
                                    5
                                </option>

                                <option value="10"
                                        selected="@(Context.Request.Query["topRegistro"] == "10")">
                                    10
                                </option>

                                <option value="20"
                                        selected="@(Context.Request.Query["topRegistro"] == "20")">
                                    20
                                </option>

                                <option value="50"
                                        selected="@(Context.Request.Query["topRegistro"] == "50")">
                                    50
                                </option>

                                <option value="100"
                                        selected="@(Context.Request.Query["topRegistro"] == "100")">
                                    100
                                </option>

                                <option value="0"
                                        selected="@(Context.Request.Query["topRegistro"] == "0")">
                                    Todos
                                </option>

                            </select>
                        </div>
                    </div>

                </div>

                <!-- Botones -->
                <div class="row mt-4">
                    <div class="col-12 d-flex gap-2">

                        <button type="submit" class="btn btn-primary px-4 shadow-sm fw-bold">
                            <i class="bi bi-search me-2"></i>Buscar
                        </button>

                        <a asp-action="Index" class="btn btn-secondary px-4 shadow-sm">
                            <i class="bi bi-eraser me-2"></i>Limpiar
                        </a>

                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

<table class="table table-striped mt-4">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Tipo Movimiento</th>
            <th>Cantidad</th>
            <th>Fecha</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-center">
                    No hay movimientos registrados
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Producto.Nombre</td>
                    <td>@item.TipoMovimiento</td>
                    <td>@item.Cantidad</td>
                    <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>

                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                            Detalle
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                            Eliminar
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>