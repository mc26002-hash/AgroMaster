@model IEnumerable<Agromercado.AppMVC.Models.MovimientosInventario>

@{
    ViewData["Title"] = "Movimientos de Inventario";
}

<h2>Movimientos de Inventario</h2>

<p>
    <a asp-action="CrearEntradaInicial" class="btn btn-secondary">
        Stock Inicial
    </a>

    <a asp-action="CrearEntrada" class="btn btn-primary">
        Registrar Entrada
    </a>

    <a asp-action="CrearSalida" class="btn btn-warning">
        Registrar Salida
    </a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Tipo Movimiento</th>
            <th>Cantidad</th>
            <th>Fecha</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-center">
                    No hay movimientos registrados
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Producto.Nombre</td>
                    <td>@item.TipoMovimiento</td>
                    <td>@item.Cantidad</td>
                    <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>

                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                            Detalle
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                            Eliminar
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<!-- 🔥 ACTUALIZACIÓN AUTOMÁTICA (TIEMPO REAL) -->
<script>
    setInterval(() => {
        location.reload();
    }, 5000);
</script>