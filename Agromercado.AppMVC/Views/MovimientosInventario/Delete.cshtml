@model Agromercado.AppMVC.Models.MovimientosInventario

@{
    ViewData["Title"] = "Eliminar Movimiento";
}

<h2>Eliminar Movimiento</h2>

<div class="alert alert-warning">
    ⚠️ Esta acción afectará el stock del producto. ¿Deseas continuar?
</div>

<h4>¿Seguro que deseas eliminar este movimiento?</h4>

<div>

    <dl class="row">

        <dt class="col-sm-3">
            Producto
        </dt>
        <dd class="col-sm-9">
            @Model.Producto.Nombre
        </dd>

        <dt class="col-sm-3">
            Tipo Movimiento
        </dt>
        <dd class="col-sm-9">
            @Model.TipoMovimiento
        </dd>

        <dt class="col-sm-3">
            Cantidad
        </dt>
        <dd class="col-sm-9">
            @Model.Cantidad
        </dd>

        <dt class="col-sm-3">
            Fecha
        </dt>
        <dd class="col-sm-9">
            @Model.Fecha.ToString("dd/MM/yyyy HH:mm")
        </dd>

    </dl>

    <form asp-action="Delete">

        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-danger">
            Eliminar
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancelar
        </a>

    </form>

</div>