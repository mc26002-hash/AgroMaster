@model Agromercado.AppMVC.Models.MovimientosInventario

@{
    ViewData["Title"] = "Eliminar Movimiento";
}

<div class="form-create-container">
    <div class="form-create-card">

        <h4 class="titulo-agro mb-4">🌾 Eliminar Movimiento</h4>
<div class="alert alert-warning">
    ⚠️ Esta acción afectará el stock del producto. ¿Deseas continuar?
</div>

<form asp-action="Delete">

    <input type="hidden" asp-for="Id" />

<div>

    <div class="row">

                    <div class="col-md-12">
                        <div class="card mt-3">
                            <div class="card-body">
                                <p><strong>Producto:</strong> @Model.Producto.Nombre</p>
                                <p><strong>Tipo Movimiento:</strong> @Model.TipoMovimiento</p>
                                <p><strong>Cantidad:</strong> @Model.Cantidad</p>
                                <p><strong>Fecha:</strong> @Model.Fecha.ToString("dd/MM/yyyy HH:mm")</p>

        </div>
        </div>
        </div>
    </div>
    </div>
    

            <div class="d-flex justify-content-end gap-2 mt-4">
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-trash me-2"></i> Eliminar
                </button>

                <a asp-action="Index" class="btn btn-secondary px-4">
                    <i class="bi bi-x-circle me-2"></i> Cancelar
                </a>
            </div>

    </form>

</div>
</div>