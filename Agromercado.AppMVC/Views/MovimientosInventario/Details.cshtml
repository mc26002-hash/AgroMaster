@model Agromercado.AppMVC.Models.MovimientosInventario

@{
    ViewData["Title"] = "Detalle Movimiento";
}

<div class="form-create-container">
    <div class="form-create-card">

        <h4 class="titulo-agro mb-4">🌾 Detalle del Movimiento</h4>

        <div class="row">
            <div class="col-md-12">

                <div class="card mt-3">
                    <div class="card-body">

            <p><strong>Producto:</strong> @Model.Producto.Nombre</p>
            <p><strong>Tipo Movimiento:</strong> @Model.TipoMovimiento</p>
            <p><strong>Cantidad:</strong> @Model.Cantidad</p>
            <p><strong>Fecha:</strong> @Model.Fecha.ToString("dd/MM/yyyy HH:mm")</p>

                    </div>
                </div>

            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">

            <a asp-action="Index" class="btn btn-secondary px-4">
                <i class="bi bi-arrow-left me-2"></i>Volver
            </a>

        </div>

    </div>
</div>