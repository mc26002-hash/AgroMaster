@{
    ViewData["Title"] = "Registrar Stock Inicial";
}



<div class="form-create-container">
    <div class="form-create-card">

        <h4 class="titulo-agro mb-4">🌾 Registrar Stock Inicial</h4>
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <div asp-validation-summary="All"></div>
            </div>
        }
        <div class="alert alert-info">
            Este proceso solo se puede realizar una vez por producto.
        </div>

        <form asp-action="CrearEntradaInicial" method="post">

            @Html.AntiForgeryToken()

            <div class="row">

                <div class="col-md-7 form-group">
                    <label>Producto</label>
                    <select name="productoId" class="form-control" asp-items="ViewBag.Productos" required>
                        <option value="">-- Seleccione un producto --</option>
                    </select>
                </div>

                <div class="col-md-5 form-group">
                    <label>Cantidad Inicial</label>
                    <input type="number" name="cantidad" class="form-control" min="1" required />
                </div>

                <div class="col-md-7 mb-3">
                    <label>Motivo</label>
                    <select name="motivo" class="form-control" asp-items="ViewBag.Motivos">
                        <option value="">-- Seleccione motivo --</option>
                    </select>
                </div>

            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <button type="submit" class="btn btn-success px-4">
                    <i class="bi bi-plus-circle me-2"></i>Registrar
                </button>

                <a asp-action="Index" class="btn btn-secondary px-4">
                    <i class="bi bi-arrow-left me-2"></i>Volver
                </a>
            </div>

        </form>

    </div>
</div>