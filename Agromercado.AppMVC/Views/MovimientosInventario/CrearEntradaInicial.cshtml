@{
    ViewData["Title"] = "Registrar Stock Inicial";
}

<h2>Registrar Stock Inicial</h2>

<div class="alert alert-info">
    Este proceso solo se puede realizar una vez por producto.
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <div asp-validation-summary="All"></div>
    </div>
}

<form asp-action="CrearEntradaInicial" method="post">

    <div class="form-group">
        <label>Producto</label>
        <select name="productoId" class="form-control" asp-items="ViewBag.Productos" required>
            <option value="">-- Seleccione un producto --</option>
        </select>
    </div>

    <div class="form-group">
        <label>Cantidad Inicial</label>
        <input type="number" name="cantidad" class="form-control" min="1" required />
    </div>

    <br>

    <button type="submit" class="btn btn-secondary">
        Registrar Stock Inicial
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Volver
    </a>

</form>