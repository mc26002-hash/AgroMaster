@model Agromercado.AppMVC.Models.Producto

<div class="form-create-container">
    <div class="form-create-card">

        <h4 class="titulo-agro mb-4">🌾 Nuevo Producto</h4>

        <form asp-action="Create" method="post">

            <div asp-validation-summary="None"></div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Categoria" class="form-label"></label>
                    <select asp-for="CategoriaId" class="form-control"
                            asp-items="@(new SelectList(ViewBag.Categorias, "Id", "Nombre"))">
                        <option value="">- Seleccione una categoría -</option>
                    </select>
                    <span asp-validation-for="CategoriaId" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Unidad de Medida</label>
                    <select asp-for="UnidadMedidaId" class="form-control"
                            asp-items="@(new SelectList(ViewBag.Unidades, "Id", "Nombre"))">
                        <option value="">- Seleccione una unidad -</option>
                    </select>
                    <span asp-validation-for="UnidadMedidaId" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Precio de Compra</label>
                    <input asp-for="PrecioCompraPromedio" class="form-control" />
                    <span asp-validation-for="PrecioCompraPromedio" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Precio de Venta</label>
                    <input asp-for="PrecioVenta" class="form-control" />
                    <span asp-validation-for="PrecioVenta" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Stock Minimo</label>
                    <input asp-for="StockMinimo" class="form-control" />
                    <span asp-validation-for="StockMinimo" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Activo" class="form-label"></label>
                    <select asp-for="Activo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                    <span asp-validation-for="Activo" class="text-danger"></span>
                </div>

            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <button type="submit" class="btn btn-success px-4">
                    <i class="bi bi-plus-lg me-2"></i>Guardar
                </button>

                <a asp-action="Index" class="btn btn-secondary px-4">
                    <i class="bi bi-x-circle me-2"></i>Cancelar
                </a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}