@model Agromercado.AppMVC.Models.Producto

<div class="form-create-container">
    <div class="form-create-card">

        <h4 class="titulo-agro mb-4">🌾 Eliminar Producto</h4>

<div class="alert alert-danger">
    ¿Estás seguro que deseas eliminar este producto?
</div>

<form asp-action="DeleteConfirmed" method="post" class="mt-3">

    <input type="hidden" asp-for="Id" />

<div class="row">
    <div class="col-md-12">
<div class="card mt-3">
    <div class="card-body">

        <p><strong>Nombre:</strong> @Model.Nombre</p>
        <p><strong>Categoría:</strong> @Model.Categoria?.Nombre</p>
        <p><strong>Unidad:</strong> @Model.UnidadMedida?.Nombre</p>
        <p><strong>Precio de venta:</strong> @Model.PrecioVenta</p>
        <p><strong>Precio Compra Promedio:</strong> @Model.PrecioCompraPromedio</p>
        <p><strong>Stock:</strong> @Model.Stock</p>
        <p><strong>Stock Mínimo:</strong> @Model.StockMinimo</p>
        <p><strong>Fecha de Registro:</strong> @Model.FechaRegistro</p>

    </div>
</div>
</div>
</div>



    <div class="d-flex justify-content-end gap-2 mt-4">
        <button type="submit" class="btn btn-danger px-4">
            <i class="bi bi-trash me-2"></i> Eliminar
        </button>

        <a asp-action="Index" class="btn btn-secondary px-4">
            <i class="bi bi-x-circle me-2"></i> Cancelar
        </a>
    </div>

</form>

</div>
</div>