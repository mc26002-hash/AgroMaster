@model IEnumerable<Agromercado.AppMVC.Models.Producto>

<h2 class="mb-4 text-danger">
    <i class="bi bi-exclamation-triangle-fill"></i> Productos con Stock Bajo
</h2>

<div class="card shadow-sm">
    <div class="card-body">

        @if (!Model.Any())
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle"></i>
                Todo está en orden 👍 No hay productos con stock bajo.
            </div>
        }
        else
        {
            <table class="table table-bordered table-hover">
                <thead class="table-danger">
                    <tr>
                        <th>Producto</th>
                        <th>Categoría</th>
                        <th>Unidad</th>
                        <th>Stock</th>
                        <th>Stock Mínimo</th>
                        <th>Estado</th>
                        <th style="width:200px;">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="table-warning">
                            <td>@item.Nombre</td>
                            <td>@item.Categoria?.Nombre</td>
                            <td>@item.UnidadMedida?.Nombre</td>
                            <td><strong class="text-danger">@item.Stock</strong></td>
                            <td>@item.StockMinimo</td>
                            <td>
                                <span class="badge bg-danger">
                                    Bajo stock
                                </span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-info btn-sm">
                                    Ver
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-warning btn-sm">
                                    Editar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="mt-3">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
        </div>

    </div>
</div>