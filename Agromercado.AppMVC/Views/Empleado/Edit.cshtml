@model Agromercado.AppMVC.Models.Empleado

<div class="form-create-container">
    <div class="form-create-card">

        <h4 class="titulo-agro mb-4">🌾 Editar Empleado</h4>

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div class="row">

                <div class="col-md-12 mb-3">
                    <label>Nombre</label>
                    <input asp-for="Nombre" class="form-control" />
                </div>

                <div class="col-md-12 mb-3">
                    <label>Correo</label>
                    <input asp-for="Correo" class="form-control" />
                </div>

                <div class="col-md-12 mb-3">
                    <label>Contraseña</label>
                    <input asp-for="Password" class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label>Rol</label>
                    <select asp-for="RolId" class="form-control"
                            asp-items="@(new SelectList(ViewBag.Roles, "Id", "Nombre", Model.RolId))">
                        <option value="">-- Seleccione un rol --</option>
                    </select>
                    <span asp-validation-for="RolId" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Activo</label>
                    <select asp-for="Activo" class="form-control">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>

            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <button type="submit" class="btn btn-warning px-4">
                    <i class="bi bi-pencil-square me-2"></i>Guardar
                </button>

                <a asp-action="Index" class="btn btn-secondary px-4">
                    <i class="bi bi-x-circle me-2"></i>Cancelar
                </a>
            </div>

        </form>

    </div>
</div>