@model IEnumerable<Agromercado.AppMVC.Models.Role>

<h2>Lista de Roles</h2>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title mb-3">Buscar Roles</h5>

            <form asp-controller="Role" asp-action="Index" method="get">
                <div class="row g-3 align-items-end">

                    <!-- 🔍 Nombre -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small">Nombre</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white">
                                <i class="bi bi-person-badge text-primary"></i>
                            </span>
                            <input type="text" name="nombre" class="form-control"
                                   placeholder="Ej: Administrador..."
                                   value="@Context.Request.Query["nombre"]" />
                        </div>
                    </div>

                    <!-- 🔢 Cantidad -->
                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted small">Cantidad</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white">
                                <i class="bi bi-list-ol text-primary"></i>
                            </span>

                            <select name="topRegistro" class="form-select">

                                <option value="5"
                                        selected="@(string.IsNullOrEmpty(Context.Request.Query["topRegistro"]) || Context.Request.Query["topRegistro"] == "5")">
                                    5
                                </option>

                                <option value="10"
                                        selected="@(Context.Request.Query["topRegistro"] == "10")">
                                    10
                                </option>

                                <option value="20"
                                        selected="@(Context.Request.Query["topRegistro"] == "20")">
                                    20
                                </option>

                                <option value="50"
                                        selected="@(Context.Request.Query["topRegistro"] == "50")">
                                    50
                                </option>

                                <option value="100"
                                        selected="@(Context.Request.Query["topRegistro"] == "100")">
                                    100
                                </option>

                                <option value="0"
                                        selected="@(Context.Request.Query["topRegistro"] == "0")">
                                    Todos
                                </option>

                            </select>
                        </div>
                    </div>

                </div>

                <!-- Botones -->
                <div class="row mt-4">
                    <div class="col-12 d-flex gap-2">

                        <button type="submit" class="btn btn-primary px-4 shadow-sm fw-bold">
                            <i class="bi bi-search me-2"></i>Buscar
                        </button>

                        <a asp-action="Index" class="btn btn-secondary px-4 shadow-sm">
                            <i class="bi bi-eraser me-2"></i>Limpiar
                        </a>

                        <a asp-action="Create" class="btn btn-success px-4 shadow-sm">
                            <i class="bi bi-plus-lg me-2"></i>Nuevo Rol
                        </a>

                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

<table class="table table-bordered mt-4">
    <thead>
        <tr>
            <th>Nombre</th>
            <th style="width:220px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalle</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                        Eliminar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>