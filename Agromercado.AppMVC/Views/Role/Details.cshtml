@model Agromercado.AppMVC.Models.Role

<div class="form-create-container">
    <div class="form-create-card">

        <h4 class="titulo-agro mb-4">🌾 Detalle del Rol</h4>

        <p><strong>Nombre:</strong> @Model.Nombre</p>

        <h4 class="titulo-agro mb-4">Empleados con este rol:</h4>

        <div class="row">
            <div class="col-md-12">

                <div class="card mt-3">
                    <div class="card-body">

                        <ul>
                            @foreach (var emp in Model.Empleados)
                            {
                                <li>@emp.Nombre</li>
                            }
                        </ul>

                    </div>
                </div>

            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <a asp-action="Index" class="btn btn-secondary px-4">
                <i class="bi bi-arrow-left me-2"></i> Volver
            </a>
        </div>

    </div>
</div>