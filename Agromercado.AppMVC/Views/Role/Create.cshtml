@model Agromercado.AppMVC.Models.Role

<div class="form-create-container">
    <div class="form-create-card">

        <h4 class="titulo-agro mb-4">🌾 Nuevo Rol</h4>

        <form asp-action="Create" method="post">

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label>Nombre</label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

            </div>

                <div class="mb-3 d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-plus-lg me-2"></i>Guardar
                    </button>

                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="bi bi-x-circle me-2"></i>Cancelar
                    </a>
                </div>

            

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}