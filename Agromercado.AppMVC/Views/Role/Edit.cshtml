@model Agromercado.AppMVC.Models.Role

<div class="form-create-container">
    <div class="form-create-card">

        <h4 class="titulo-agro mb-4">🌾 Editar Rol</h4>

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label">Nombre</label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">

                <button type="submit" class="btn btn-warning px-4">
                    <i class="bi bi-pencil-square me-2"></i>Guardar
                </button>

                <a asp-action="Index" class="btn btn-secondary px-4">
                    <i class="bi bi-x-circle me-2"></i>Cancelar
                </a>

            </div>

        </form>

    </div>
</div>