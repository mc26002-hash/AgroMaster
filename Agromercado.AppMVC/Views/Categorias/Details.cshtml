@model Agromercado.AppMVC.Models.Categoria

<div class="form-create-container">
    <div class="form-create-card">

        <h4 class="titulo-agro mb-4">🌾 Detalle Categoría</h4>

        <div class="row">
            <div class="col-md-12">
<div class="card">
    <div class="card-body">
        <p><strong>Nombre:</strong> @Model.Nombre</p>
        <p><strong>Descripción:</strong> @Model.Descripcion</p>
        <p><strong>Estado:</strong> @(Model.Estado ? "Activa" : "Inactiva")</p>

                    </div>
                </div>

            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">

            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">
                <i class="bi bi-pencil-square me-2"></i>Editar
            </a>

            <a asp-action="Index" class="btn btn-secondary px-4">
                <i class="bi bi-arrow-left me-2"></i>Volver
            </a>

        </div>

    </div>
</div>